{
  "name": "magictrust",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "api-client:create": "pnpm --filter @magictrust/database api-client:create",
    "admin:user:create": "pnpm --filter @magictrust/database admin:user:create",
    "pii:backfill": "pnpm --filter @magictrust/database pii:backfill",
    "webhook:create": "pnpm --filter @magictrust/database webhook:create",
    "webhook:deliver": "pnpm --filter @magictrust/database webhook:deliver"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript-eslint": "^8.19.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
